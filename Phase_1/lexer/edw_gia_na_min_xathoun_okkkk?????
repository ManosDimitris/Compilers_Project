 void printTree(CommentNode *Node, int depth){
    cout << "Level " << depth << ": " << Node->comment_content << endl;
    //cout << "level " << depth << " has " << Node->children.size() << " nodes" << endl;
    for(CommentNode *child : Node->children){
        printTree(child, depth + 1);
    }

 }