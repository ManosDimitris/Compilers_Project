Grammar

    0 $accept: program $end

    1 program: stmntlist

    2 stmntlist: ε
    3          | stmt
    4          | stmntlist stmt

    5 stmt: expr SEMICOLON
    6     | ifstmt
    7     | whilestmt
    8     | forstmt
    9     | returnstmt
   10     | BREAK SEMICOLON
   11     | CONTINUE SEMICOLON
   12     | block
   13     | funcdef
   14     | SEMICOLON

   15 expr: assignexpr
   16     | expr op expr
   17     | term

   18 op: PLUS
   19   | MINUS
   20   | MULTI
   21   | DIV
   22   | MOD
   23   | GREATER
   24   | GREATER_EQUAL
   25   | LESS
   26   | LESS_EQUAL
   27   | EQUAL
   28   | NEQUAL
   29   | AND
   30   | OR

   31 term: LEFT_PARENTHES expr RIGHT_PARENTHES
   32     | MINUS expr
   33     | NOT expr
   34     | UPLUS lvalue
   35     | lvalue UPLUS
   36     | UMINUS lvalue
   37     | lvalue UMINUS
   38     | primary

   39 assignexpr: lvalue ASSIGN expr

   40 primary: lvalue
   41        | call
   42        | objectdef
   43        | LEFT_PARENTHES funcdef RIGHT_PARENTHES
   44        | const

   45 lvalue: ID
   46       | LOCAL ID
   47       | DCOLON ID
   48       | member

   49 member: lvalue DOT ID
   50       | lvalue LEFT_BRACKET expr RIGHT_BRACKET
   51       | call DOT ID
   52       | call LEFT_BRACKET expr RIGHT_BRACKET

   53 call: call LEFT_PARENTHES elist RIGHT_PARENTHES
   54     | lvalue callsuffix
   55     | LEFT_PARENTHES funcdef RIGHT_PARENTHES LEFT_PARENTHES elist RIGHT_PARENTHES

   56 callsuffix: normcall
   57           | methodcall

   58 normcall: LEFT_PARENTHES elist RIGHT_PARENTHES

   59 methodcall: DOTS ID LEFT_PARENTHES elist RIGHT_PARENTHES

   60 elist: ε
   61      | expr
   62      | elist COMMA expr

   63 objectdef: LEFT_BRACKET RIGHT_BRACKET
   64          | LEFT_BRACKET elist RIGHT_BRACKET
   65          | LEFT_BRACKET indexed RIGHT_BRACKET

   66 indexed: indexedelemlist

   67 indexedelemlist: ε
   68                | indexedelem
   69                | indexedelem COMMA indexedelemlist

   70 indexedelem: LEFT_CBRACKET expr COLON expr RIGHT_CBRACKET

   71 block: LEFT_CBRACKET stmntlist RIGHT_CBRACKET

   72 funcdef: FUNCTION LEFT_PARENTHES idlist RIGHT_PARENTHES block
   73        | FUNCTION ID LEFT_PARENTHES idlist RIGHT_PARENTHES block

   74 const: INTCONST
   75      | REAL
   76      | STRING
   77      | NIL
   78      | TRUE
   79      | FALSE

   80 idlist: ε
   81       | ID
   82       | idlist COMMA ID

   83 ifstmt: IF LEFT_PARENTHES expr RIGHT_PARENTHES stmt
   84       | ifstmt elsestmt

   85 elsestmt: ELSE stmt

   86 whilestmt: WHILE LEFT_PARENTHES expr RIGHT_PARENTHES stmt

   87 forstmt: FOR LEFT_PARENTHES elist SEMICOLON expr SEMICOLON elist RIGHT_PARENTHES stmt

   88 returnstmt: RETURN SEMICOLON
   89           | RETURN expr SEMICOLON


